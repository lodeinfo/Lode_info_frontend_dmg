{
  "name": "lodeinfo-desktop",
  "version": "1.0.0",
  "description": "LodeInfo Desktop Assistant",
  "main": "main.js",
  "author": "LodeInfo",
  "license": "ISC",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "electron-dev": "concurrently \"vite\" \"electron .\"",
    "dist": "vite build && electron-builder",
    "win": "vite build && electron-builder --win",
    "mac": "vite build && electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.lodeinfo.desktop",
    "productName": "LodeInfo",
    "asar": true,
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "public/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/lodeinfo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "icon": "public/lodeinfo.ico",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "title": "LodeInfo",
      "window": {
        "width": 540,
        "height": 380
      }
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.0",
    "antd": "^6.1.1",
    "axios": "^1.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.11.0"
  }
}